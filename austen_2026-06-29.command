#!/bin/bash
osascript << 'APPLESCRIPT'
tell application "Microsoft Outlook"
    activate
    set newMessage to make new outgoing message with properties {subject:"This Week in AI — Governments Throttle Models Too Powerful to Release", content:"<!DOCTYPE html><html lang=\"en\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><meta name=\"color-scheme\" content=\"light only\"><meta name=\"supported-color-schemes\" content=\"light only\"><!--[if gte mso 9]><xml><o:OfficeDocumentSettings><o:AllowPNG/></o:OfficeDocumentSettings></xml><![endif]--><style>:root { color-scheme: light only; }</style></head><body style=\"margin:0;padding:0;background-color:#f8f4e3;font-family:Geist,Arial,Helvetica,sans-serif\" bgcolor=\"#f8f4e3\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#f8f4e3\" style=\"background-color:#f8f4e3\"><tr><td align=\"center\" style=\"padding:32px 16px;background-color:#f8f4e3\">  <table width=\"620\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:620px;width:100%\">    <!-- HEADER -->    <tr>      <td style=\"background:#10131b;border-radius:12px 12px 0 0;padding:40px 36px 36px;border-bottom:3px solid #bf5631\" bgcolor=\"#10131b\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td>              <p style=\"margin:0 0 8px 0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;font-weight:600\">                <font color=\"#ffffff\">Weekly Briefing &nbsp;·&nbsp; June 29, 2026</font>              </p>              <p style=\"margin:0;font-size:28px;font-weight:800;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;line-height:1.2\">                <font color=\"#ffffff\"><b>This Week</b></font><font color=\"#cccccc\"><b> in AI</b></font>              </p>              <p style=\"margin:12px 0 0 0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                <font color=\"#cccccc\">Two of the world's most powerful AI models are being held back by governments right now — and that tells you everything about where the frontier of AI has arrived.</font>              </p>            </td>            <td width=\"80\" align=\"right\" valign=\"top\">              <p style=\"margin:0;font-size:22px;font-weight:800;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;letter-spacing:-0.03em;line-height:1\">                <font color=\"#ffffff\"><b>ramsac</b></font>              </p>            </td>          </tr>        </table>      </td>    </tr>    <!-- BODY -->    <tr>      <td style=\"background:#f8f4e3;padding:28px 32px 8px;border-left:1px solid #e6dcc4;border-right:1px solid #e6dcc4\" bgcolor=\"#f8f4e3\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td style=\"padding:28px 0 20px 0;border-top:1px solid #e6dcc4\">              <p style=\"margin:0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;font-weight:700\">                <font color=\"#bf5631\">Top 5 at a Glance — click to read the full edition online</font>              </p>            </td>          </tr>                  <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #e6dcc4;border-left:3px solid #bf5631\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#bf5631\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#bf5631;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">1</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;line-height:1.3\">                          <font color=\"#10131b\"><b>Fable 5 Returning, GPT-5.6 Restricted: Governments Are Now Gatekeeping the Most Powerful AI</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#bf5631\">Wired AI / TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#5f5a52\">The Trump administration is preparing to lift its ban on Anthropic's Fable 5 within days, while simultaneously asking OpenAI to slow-roll its new GPT-5.6 model to a select group of partners only. Two frontier models held back by government action in the same week is not a coincidence — it is a signal that AI capability has entered a new political era.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #e6dcc4;border-left:3px solid #bf5631\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#bf5631\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#bf5631;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">2</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;line-height:1.3\">                          <font color=\"#10131b\"><b>Google's Gemini 3.5 Flash Can Now Use Your Computer — Not Just Answer Questions About It</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#bf5631\">Google DeepMind</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#5f5a52\">Google DeepMind has introduced <span class=\"ai-term\" data-def=\"A capability that lets an AI take direct control of a computer — clicking buttons, typing into fields, opening files, and completing tasks inside real software — rather than just telling a human what to do. Think of it as giving the AI a pair of hands, not just a voice.\">computer use</span> capabilities in Gemini 3.5 Flash, enabling the <span class=\"ai-term\" data-def=\"A piece of AI software that can carry out multi-step tasks on its own without a human guiding every click. Unlike a chatbot that just answers questions, an agent can take actions: send emails, look up records, process refunds, or schedule meetings. Think of it as a digital employee that follows instructions and gets things done independently.\">AI agent</span> to interact directly with software on a computer rather than simply describing what to do. This is the Microsoft 365 story every RAMSAC client needs to hear.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #e6dcc4;border-left:3px solid #bf5631\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#bf5631\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#bf5631;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">3</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;line-height:1.3\">                          <font color=\"#10131b\"><b>A Cancer Patient Fed His Medical Data to Claude — and Got Insights His Doctors Hadn't Considered</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#bf5631\">TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#5f5a52\">Connor Christou, a founder diagnosed with cancer, loaded his blood results, scan data, wearable output, and journal entries into Claude and used it to navigate his treatment. The story is a vivid demonstration of what AI does when someone gives it everything — and it is a powerful talking point for any client who thinks AI is just a productivity tool.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #e6dcc4;border-left:3px solid #bf5631\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#bf5631\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#bf5631;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">4</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;line-height:1.3\">                          <font color=\"#10131b\"><b>OpenAI and Broadcom Build Jalapeño: A Custom Chip That Could End Big Tech's Nvidia Dependence</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#bf5631\">OpenAI Blog / TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#5f5a52\">OpenAI and Broadcom have unveiled Jalapeño, a custom AI chip built specifically for running large language models at scale. It joins a wave of custom silicon from Google, Apple, and SpaceX — and it signals that the infrastructure powering AI is about to become faster, cheaper, and far more competitive.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #e6dcc4;border-left:3px solid #bf5631\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#bf5631\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#bf5631;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">5</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;line-height:1.3\">                          <font color=\"#10131b\"><b>Anthropic Accuses Alibaba of Running the Largest AI Model Cloning Attack Ever Recorded</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#bf5631\">Ars Technica AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#5f5a52\">Anthropic has accused Alibaba of using 25,000 accounts to extract data from Claude across 28.8 million exchanges in what it calls the largest <span class=\"ai-term\" data-def=\"An attack where someone tries to copy an AI model&#39;s intelligence by asking it millions of questions and recording its answers, then using those answers to train a copycat AI — without ever paying to build the original. It is the AI equivalent of reverse-engineering a recipe by ordering the same dish thousands of times.\">model cloning</span> attack ever attempted. This story is not primarily about one company's legal dispute — it is a warning about a new category of AI-specific threat that every business using AI tools needs to understand.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        </table>      </td>    </tr>    <!-- READ ONLINE BUTTON -->    <tr>      <td style=\"background:#f8f4e3;padding:0 32px 24px;border-left:1px solid #e6dcc4;border-right:1px solid #e6dcc4\" bgcolor=\"#f8f4e3\">        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">          <tr>            <td align=\"center\">              <a href=\"https://ironbridge-ai.github.io/Austen/austen_2026-06-29.html\" target=\"_blank\"                 style=\"display:inline-block;background:#bf5631;color:#ffffff;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;font-size:13px;font-weight:700;text-decoration:none;padding:12px 28px;border-radius:8px\">                <font color=\"#ffffff\"><b>Read full edition online &rarr;</b></font>              </a>            </td>          </tr>        </table>      </td>    </tr>    <!-- FOOTER -->    <tr>      <td style=\"background:#10131b;border-radius:0 0 12px 12px;padding:28px 36px;border:1px solid #10131b\" bgcolor=\"#10131b\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td>              <p style=\"margin:0 0 4px 0;font-size:15px;font-weight:700;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif\">                <font color=\"#ffffff\"><b>Stay curious, stay ahead.</b></font>              </p>              <p style=\"margin:0;font-size:13px;font-family:Geist,Arial,sans-serif\">                <font color=\"#999999\">See you next week.</font>              </p>            </td>            <td align=\"right\">              <p style=\"margin:0;font-size:11px;font-weight:800;font-family:'Install Rounded','Nunito',Geist,Arial,sans-serif;letter-spacing:-0.02em\">                <font color=\"#ffffff\"><b>ramsac</b></font>              </p>              <p style=\"margin:2px 0 0 0;font-size:10px;font-family:Geist,Arial,sans-serif\">                <font color=\"#666666\">Weekly AI Briefing</font>              </p>            </td>          </tr>        </table>      </td>    </tr>  </table></td></tr></table></body></html>"}
    open newMessage
end tell

APPLESCRIPT
