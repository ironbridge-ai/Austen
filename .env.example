# Austen — AI News Digest credentials
# Copy this file to ".env" (same folder) and fill in real values.
# The .env file is gitignored and auto-loaded by austen.py at startup.

# Anthropic API key (via the internal LiteLLM proxy)
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxx

# Base URL of the LiteLLM proxy that serves the model
ANTHROPIC_BASE_URL=http://ib-infra-litellm-01:4000/

# Optional: model to use. Default is azure-eur-geolocated/gpt-5.5-2.
# Must be a model your team is allowed to access on the proxy
# (e.g. azure-eur-geolocated/gpt-5.4, azure-uk-geolocated/Llama-3.3-70B-Instruct).
# AUSTEN_MODEL=azure-eur-geolocated/gpt-5.5-2
