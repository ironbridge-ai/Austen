# Austen — AI News Digest credentials
# Copy this file to ".env" (same folder) and fill in real values.
# The .env file is gitignored and auto-loaded by austen.py at startup.

# LiteLLM virtual key (via the internal proxy). Replace the placeholder below.
ANTHROPIC_API_KEY=sk-REPLACE_ME

# Base URL of the LiteLLM proxy that serves the model
ANTHROPIC_BASE_URL=http://ib-infra-litellm-01:4000/

# Optional: model to use. Default is eu.anthropic.claude-opus-4-6-v1 (Claude
# Opus, EU data residency — the flagship-weekly model). Must be one your
# key/team can access on the proxy. Alternatives:
#   eu.anthropic.claude-sonnet-4-6            (balanced, cheaper/faster)
#   eu.anthropic.claude-haiku-4-5-20251001-v1:0 (fastest/cheapest)
#   azure-eur-geolocated/gpt-5.5-2            (non-Claude fallback)
# AUSTEN_MODEL=eu.anthropic.claude-opus-4-6-v1
