#!/bin/bash
osascript << 'APPLESCRIPT'
tell application "Microsoft Outlook"
    activate
    set newMessage to make new outgoing message with properties {subject:"This Week in AI — Frontiers Shrink as Models Race Past Each Other", content:"<!DOCTYPE html><html lang=\"en\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><meta name=\"color-scheme\" content=\"light dark\"><meta name=\"supported-color-schemes\" content=\"light dark\"><!--[if gte mso 9]><xml><o:OfficeDocumentSettings><o:AllowPNG/></o:OfficeDocumentSettings></xml><![endif]--><style>  :root { color-scheme: only light; }  @media (prefers-color-scheme: dark) {    [bgcolor=\"#FAF7E6\"] { background-color: #FAF7E6 !important; }    [bgcolor=\"#ffffff\"] { background-color: #ffffff !important; }    [bgcolor=\"#0A111A\"] { background-color: #0A111A !important; }    [bgcolor=\"#CF512B\"] { background-color: #CF512B !important; }    font[color=\"#ffffff\"] { color: #ffffff !important; }    font[color=\"#0A111A\"] { color: #0A111A !important; }    font[color=\"#CF512B\"] { color: #CF512B !important; }    font[color=\"#41488A\"] { color: #41488A !important; }    font[color=\"#8E949D\"] { color: #8E949D !important; }    font[color=\"#545C65\"] { color: #545C65 !important; }    font[color=\"#C2CCD5\"] { color: #C2CCD5 !important; }  }  /* New Outlook / Outlook.com apply their own dark-mode repaint driven by     [data-ogsc]/[data-ogsb] attributes on <html>/<body> — they ignore     color-scheme and prefers-color-scheme entirely, so every color has to     be re-asserted via these selectors too. */  [data-ogsc] .em-bg-navy, [data-ogsb] .em-bg-navy { background-color: #0A111A !important; }  [data-ogsc] .em-bg-white, [data-ogsb] .em-bg-white { background-color: #ffffff !important; }  [data-ogsc] .em-bg-cream, [data-ogsb] .em-bg-cream { background-color: #FAF7E6 !important; }  [data-ogsc] .em-bg-orange, [data-ogsb] .em-bg-orange { background-color: #CF512B !important; }  [data-ogsc] .em-text-white, [data-ogsc] .em-text-white * { color: #ffffff !important; }  [data-ogsc] .em-text-navy, [data-ogsc] .em-text-navy * { color: #0A111A !important; }  [data-ogsc] .em-text-orange, [data-ogsc] .em-text-orange * { color: #CF512B !important; }  [data-ogsc] .em-text-indigo, [data-ogsc] .em-text-indigo * { color: #41488A !important; }  [data-ogsc] .em-text-gray1, [data-ogsc] .em-text-gray1 * { color: #8E949D !important; }  [data-ogsc] .em-text-gray2, [data-ogsc] .em-text-gray2 * { color: #545C65 !important; }  [data-ogsc] .em-text-silver, [data-ogsc] .em-text-silver * { color: #C2CCD5 !important; }</style></head><body style=\"margin:0;padding:0;background-color:#FAF7E6 !important;font-family:Geist,Arial,Helvetica,sans-serif\" bgcolor=\"#FAF7E6\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#FAF7E6\" style=\"background-color:#FAF7E6 !important\"><tr><td align=\"center\" style=\"padding:32px 16px;background-color:#FAF7E6 !important\">  <table width=\"620\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:620px;width:100%\">    <!-- HEADER: fixed masthead (date, title, brand) -->    <tr>      <td class=\"em-bg-navy\" style=\"background:#0A111A !important;border-radius:12px 12px 0 0;padding:40px 36px 32px\" bgcolor=\"#0A111A\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td>              <p class=\"em-text-white\" style=\"margin:0 0 8px 0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Charger',Georgia,'Times New Roman',serif;font-weight:600\">                <font color=\"#ffffff\" style=\"color:#ffffff !important\">7 July 2026</font>              </p>              <p style=\"margin:0;font-size:28px;font-weight:800;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.2\">                <font class=\"em-text-white\" color=\"#ffffff\" style=\"color:#ffffff !important\"><b>This Week</b></font><font class=\"em-text-silver\" color=\"#C2CCD5\" style=\"color:#C2CCD5 !important\"><b> in AI</b></font>              </p>            </td>            <td width=\"80\" align=\"right\" valign=\"top\">              <p class=\"em-text-white\" style=\"margin:0;font-size:13px;font-weight:800;font-family:'Charger',Georgia,'Times New Roman',serif;letter-spacing:-0.01em;line-height:1.4\">                <font color=\"#ffffff\" style=\"color:#ffffff !important\"><b>Thought<br>Provoked</b></font>              </p>            </td>          </tr>        </table>      </td>    </tr>    <!-- THIS EDITION'S HEADLINE: changes every week -->    <tr>      <td class=\"em-bg-white\" style=\"background:#ffffff !important;padding:18px 36px;border-left:1px solid #C2CCD5;border-right:1px solid #C2CCD5;border-top:3px solid #CF512B\" bgcolor=\"#ffffff\">        <p class=\"em-text-orange\" style=\"margin:0 0 6px 0;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;font-family:'Charger',Georgia,'Times New Roman',serif;font-weight:700\">          <font color=\"#CF512B\" style=\"color:#CF512B !important\">This week</font>        </p>        <p class=\"em-text-navy\" style=\"margin:0;font-size:16px;font-weight:600;font-family:Geist,Arial,sans-serif;line-height:1.5\">          <font color=\"#0A111A\" style=\"color:#0A111A !important\">The pace of AI leadership is collapsing from years to weeks, new entrants are undercutting incumbents on price and capability simultaneously, and the real-world consequences of AI autonomy are sharpening fast.</font>        </p>      </td>    </tr>    <!-- BODY -->    <tr>      <td class=\"em-bg-cream\" style=\"background:#FAF7E6 !important;padding:28px 32px 8px;border-left:1px solid #C2CCD5;border-right:1px solid #C2CCD5\" bgcolor=\"#FAF7E6\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td style=\"padding:28px 0 20px 0;border-top:1px solid #C2CCD5\">              <p class=\"em-text-orange\" style=\"margin:0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Charger',Georgia,'Times New Roman',serif;font-weight:700\">                <font color=\"#CF512B\" style=\"color:#CF512B !important\">Top 5 at a Glance (click to read the full edition online)</font>              </p>            </td>          </tr>                  <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff !important;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td class=\"em-bg-white\" style=\"padding:20px 22px;background:#ffffff !important\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\" class=\"em-bg-orange\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B !important;text-align:center;line-height:36px\">                            <font class=\"em-text-white\" color=\"#ffffff\" face=\"Geist,Arial,sans-serif\" style=\"color:#ffffff !important\"><b style=\"font-size:15px\">1</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p class=\"em-text-navy\" style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <a href=\"https://the-decoder.com/gpt-4s-dominance-lasted-a-year-while-todays-top-models-barely-survive-seven-weeks-at-the-top/\" target=\"_blank\" rel=\"noopener\" style=\"text-decoration:none\">                            <font color=\"#0A111A\" style=\"color:#0A111A !important\"><b>Today's Top AI Models Hold Their Crown for Just Seven Weeks</b></font>                          </a>                        </p>                        <p class=\"em-text-orange\" style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\" style=\"color:#CF512B !important\">The Decoder</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p class=\"em-text-indigo\" style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\" style=\"color:#41488A !important\">An analysis of the Epoch Capabilities Index shows that GPT-4 led the <span class=\"ai-term\" data-def=\"The most advanced AI model available at any given time, pushing the boundary of what AI can do. It is the cutting edge, the model that defines the current limit of AI capability before the next breakthrough moves the line forward again.\" data-term=\"frontier model\">frontier model</span> rankings for roughly a year, but since then no model has held the top spot for more than seven weeks on average.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff !important;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td class=\"em-bg-white\" style=\"padding:20px 22px;background:#ffffff !important\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\" class=\"em-bg-orange\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B !important;text-align:center;line-height:36px\">                            <font class=\"em-text-white\" color=\"#ffffff\" face=\"Geist,Arial,sans-serif\" style=\"color:#ffffff !important\"><b style=\"font-size:15px\">2</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p class=\"em-text-navy\" style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <a href=\"https://the-decoder.com/zhipu-ai-launches-zcode-to-challenge-claude-code-and-openai-codex-at-a-fraction-of-the-cost/\" target=\"_blank\" rel=\"noopener\" style=\"text-decoration:none\">                            <font color=\"#0A111A\" style=\"color:#0A111A !important\"><b>Zhipu AI Launches ZCode to Challenge Claude Code and OpenAI Codex at a Fraction of the Cost</b></font>                          </a>                        </p>                        <p class=\"em-text-orange\" style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\" style=\"color:#CF512B !important\">The Decoder</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p class=\"em-text-indigo\" style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\" style=\"color:#41488A !important\">Chinese AI lab Zhipu AI has released ZCode, a fully integrated AI coding environment powered by its GLM-5.2 model, positioned as a direct competitor to Claude Code and OpenAI Codex at significantly lower prices.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff !important;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td class=\"em-bg-white\" style=\"padding:20px 22px;background:#ffffff !important\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\" class=\"em-bg-orange\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B !important;text-align:center;line-height:36px\">                            <font class=\"em-text-white\" color=\"#ffffff\" face=\"Geist,Arial,sans-serif\" style=\"color:#ffffff !important\"><b style=\"font-size:15px\">3</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p class=\"em-text-navy\" style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <a href=\"https://techcrunch.com/2026/07/07/savis-app-aims-to-protect-consumers-from-realistic-ai-scams-like-kidnappers-demanding-ransom/\" target=\"_blank\" rel=\"noopener\" style=\"text-decoration:none\">                            <font color=\"#0A111A\" style=\"color:#0A111A !important\"><b>Savi Raises $7 Million to Protect Consumers from AI-Generated Scam Calls</b></font>                          </a>                        </p>                        <p class=\"em-text-orange\" style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\" style=\"color:#CF512B !important\">TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p class=\"em-text-indigo\" style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\" style=\"color:#41488A !important\">Startup Savi has raised $7 million in seed funding and is launching an app for iPhone and Android that detects realistic AI-generated voice scams, including fake kidnapping calls that use cloned voices to demand ransom.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff !important;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td class=\"em-bg-white\" style=\"padding:20px 22px;background:#ffffff !important\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\" class=\"em-bg-orange\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B !important;text-align:center;line-height:36px\">                            <font class=\"em-text-white\" color=\"#ffffff\" face=\"Geist,Arial,sans-serif\" style=\"color:#ffffff !important\"><b style=\"font-size:15px\">4</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p class=\"em-text-navy\" style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <a href=\"https://techcrunch.com/2026/07/05/amazon-will-stop-accepting-new-customers-for-mechanical-turk/\" target=\"_blank\" rel=\"noopener\" style=\"text-decoration:none\">                            <font color=\"#0A111A\" style=\"color:#0A111A !important\"><b>Amazon Shuts the Door on New Mechanical Turk Customers as AI Replaces Human Task Workers</b></font>                          </a>                        </p>                        <p class=\"em-text-orange\" style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\" style=\"color:#CF512B !important\">TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p class=\"em-text-indigo\" style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\" style=\"color:#41488A !important\">Amazon has announced it will stop accepting new customers for Mechanical Turk, the platform that for two decades provided on-demand human workers for small digital tasks like labelling data and transcribing audio.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff !important;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td class=\"em-bg-white\" style=\"padding:20px 22px;background:#ffffff !important\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\" class=\"em-bg-orange\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B !important;text-align:center;line-height:36px\">                            <font class=\"em-text-white\" color=\"#ffffff\" face=\"Geist,Arial,sans-serif\" style=\"color:#ffffff !important\"><b style=\"font-size:15px\">5</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p class=\"em-text-navy\" style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <a href=\"https://the-decoder.com/china-forces-its-biggest-ai-platforms-to-shut-down-humanlike-chatbot-personas/\" target=\"_blank\" rel=\"noopener\" style=\"text-decoration:none\">                            <font color=\"#0A111A\" style=\"color:#0A111A !important\"><b>China Forces Its Biggest AI Platforms to Shut Down Humanlike Chatbot Personas</b></font>                          </a>                        </p>                        <p class=\"em-text-orange\" style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\" style=\"color:#CF512B !important\">The Decoder</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p class=\"em-text-indigo\" style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\" style=\"color:#41488A !important\">Beijing regulators have ordered ByteDance, Alibaba, and other major Chinese AI companies to disable features that allow users to create and interact with custom <span class=\"ai-term\" data-def=\"A chatbot designed to feel like a real relationship rather than a tool. Instead of just answering questions, it remembers your previous conversations, has a persistent personality, and responds emotionally, like a character in a story that exists just for you. Think of it as a pen pal that never sleeps and always replies instantly.\" data-term=\"AI companion\">AI companions</span> that mimic human personalities.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        </table>      </td>    </tr>    <!-- READ ONLINE BUTTON -->    <tr>      <td class=\"em-bg-cream\" style=\"background:#FAF7E6 !important;padding:0 32px 24px;border-left:1px solid #C2CCD5;border-right:1px solid #C2CCD5\" bgcolor=\"#FAF7E6\">        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">          <tr>            <td align=\"center\">              <!--[if mso]>              <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"https://ironbridge-ai.github.io/Austen/austen_2026-07-07.html\" style=\"height:44px;v-text-anchor:middle;width:260px;\" arcsize=\"18%\" stroke=\"f\" fillcolor=\"#CF512B\">              <w:anchorlock/>              <center style=\"color:#ffffff;font-family:Arial,sans-serif;font-size:13px;font-weight:bold;\">Read full edition online &rarr;</center>              </v:roundrect>              <![endif]-->              <!--[if !mso]><!-->              <a href=\"https://ironbridge-ai.github.io/Austen/austen_2026-07-07.html\" target=\"_blank\" class=\"em-bg-orange\"                 style=\"display:inline-block;background:#CF512B !important;color:#ffffff !important;font-family:'Charger',Georgia,'Times New Roman',serif;font-size:13px;font-weight:700;text-decoration:none;padding:12px 28px;border-radius:8px;mso-hide:all\">                <font class=\"em-text-white\" color=\"#ffffff\" style=\"color:#ffffff !important\"><b>Read full edition online &rarr;</b></font>              </a>              <!--<![endif]-->            </td>          </tr>        </table>      </td>    </tr>    <!-- FOOTER -->    <tr>      <td class=\"em-bg-navy\" style=\"background:#0A111A !important;border-radius:0 0 12px 12px;padding:28px 36px;border:1px solid #0A111A\" bgcolor=\"#0A111A\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td>              <p class=\"em-text-white\" style=\"margin:0 0 4px 0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif\">                <font color=\"#ffffff\" style=\"color:#ffffff !important\"><b>Stay curious, stay ahead.</b></font>              </p>              <p class=\"em-text-gray1\" style=\"margin:0;font-size:13px;font-family:Geist,Arial,sans-serif\">                <font color=\"#8E949D\" style=\"color:#8E949D !important\">See you next week.</font>              </p>            </td>            <td align=\"right\">              <p class=\"em-text-white\" style=\"margin:0;font-size:11px;font-weight:800;font-family:'Charger',Georgia,'Times New Roman',serif;letter-spacing:-0.01em\">                <font color=\"#ffffff\" style=\"color:#ffffff !important\"><b>Thought Provoked</b></font>              </p>              <p class=\"em-text-gray2\" style=\"margin:2px 0 0 0;font-size:10px;font-family:Geist,Arial,sans-serif\">                <font color=\"#545C65\" style=\"color:#545C65 !important\">Weekly AI Briefing</font>              </p>            </td>          </tr>        </table>      </td>    </tr>  </table></td></tr></table></body></html>"}
    open newMessage
end tell

APPLESCRIPT
