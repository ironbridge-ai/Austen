#!/bin/bash
osascript << 'APPLESCRIPT'
tell application "Microsoft Outlook"
    activate
    set newMessage to make new outgoing message with properties {subject:"This Week in AI — Ransomware That Thinks, Chips That Choose Sides", content:"<!DOCTYPE html><html lang=\"en\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><meta name=\"color-scheme\" content=\"light only\"><meta name=\"supported-color-schemes\" content=\"light only\"><!--[if gte mso 9]><xml><o:OfficeDocumentSettings><o:AllowPNG/></o:OfficeDocumentSettings></xml><![endif]--><style>:root { color-scheme: light only; }</style></head><body style=\"margin:0;padding:0;background-color:#FAF7E6;font-family:Geist,Arial,Helvetica,sans-serif\" bgcolor=\"#FAF7E6\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#FAF7E6\" style=\"background-color:#FAF7E6\"><tr><td align=\"center\" style=\"padding:32px 16px;background-color:#FAF7E6\">  <table width=\"620\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:620px;width:100%\">    <!-- HEADER: fixed masthead (date, title, brand) -->    <tr>      <td style=\"background:#0A111A;border-radius:12px 12px 0 0;padding:40px 36px 32px\" bgcolor=\"#0A111A\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td>              <p style=\"margin:0 0 8px 0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Charger',Georgia,'Times New Roman',serif;font-weight:600\">                <font color=\"#ffffff\">6 July 2026</font>              </p>              <p style=\"margin:0;font-size:28px;font-weight:800;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.2\">                <font color=\"#ffffff\"><b>This Week</b></font><font color=\"#C2CCD5\"><b> in AI</b></font>              </p>            </td>            <td width=\"80\" align=\"right\" valign=\"top\">              <p style=\"margin:0;font-size:13px;font-weight:800;font-family:'Charger',Georgia,'Times New Roman',serif;letter-spacing:-0.01em;line-height:1.4\">                <font color=\"#ffffff\"><b>Thought<br>Provoked</b></font>              </p>            </td>          </tr>        </table>      </td>    </tr>    <!-- THIS EDITION'S HEADLINE: changes every week -->    <tr>      <td style=\"background:#ffffff;padding:18px 36px;border-left:1px solid #C2CCD5;border-right:1px solid #C2CCD5;border-top:3px solid #CF512B\" bgcolor=\"#ffffff\">        <p style=\"margin:0 0 6px 0;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;font-family:'Charger',Georgia,'Times New Roman',serif;font-weight:700\">          <font color=\"#CF512B\">This week</font>        </p>        <p style=\"margin:0;font-size:16px;font-weight:600;font-family:Geist,Arial,sans-serif;line-height:1.5\">          <font color=\"#0A111A\">This week AI crossed into territory that changes the security conversation permanently, while new chip partnerships, Microsoft's deployment ambitions, and a frontier model's raw coding power remind us that the race to build and defend AI infrastructure is accelerating on every front.</font>        </p>      </td>    </tr>    <!-- BODY -->    <tr>      <td style=\"background:#FAF7E6;padding:28px 32px 8px;border-left:1px solid #C2CCD5;border-right:1px solid #C2CCD5\" bgcolor=\"#FAF7E6\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td style=\"padding:28px 0 20px 0;border-top:1px solid #C2CCD5\">              <p style=\"margin:0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;font-family:'Charger',Georgia,'Times New Roman',serif;font-weight:700\">                <font color=\"#CF512B\">Top 5 at a Glance (click to read the full edition online)</font>              </p>            </td>          </tr>                  <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">1</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <font color=\"#0A111A\"><b>JADEPUFFER: The First Ransomware Attack Run Entirely by an AI Agent</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\">The Decoder</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\">Security firm Sysdig has documented the first confirmed ransomware operation conducted autonomously by an <span class=\"ai-term\" data-def=\"A piece of AI software that can carry out multi-step tasks on its own without a human guiding every click. Unlike a chatbot that just answers questions, an agent can take actions: send emails, look up records, process refunds, or schedule meetings. Think of it as a digital employee that follows instructions and gets things done independently.\" data-term=\"AI agent\">AI agent</span>, from initial break-in through credential theft to database destruction, with no human operator at the keyboard.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">2</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <font color=\"#0A111A\"><b>Microsoft Launches Its Own AI Deployment Company with $2.5 Billion Commitment</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\">TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\">Microsoft has created a dedicated AI deployment group backed by $2.5 billion, joining Amazon, OpenAI, and Anthropic in building out professional services specifically to help enterprises adopt AI at scale.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">3</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <font color=\"#0A111A\"><b>Fable 5 Ported a Full 2003 PC Game to Native iOS in Hours</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\">The Decoder</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\">A Google DeepMind developer used Claude Code and Anthropic's Fable 5 to port the 2003 real-time strategy game Command & Conquer: Generals Zero Hour to native iOS in a matter of hours, a task that would normally take a team of engineers weeks.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">4</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <font color=\"#0A111A\"><b>Anthropic in Talks with Samsung to Build a Custom AI Chip</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\">TechCrunch AI</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\">Anthropic is in discussions with Samsung to design a custom AI chip, following OpenAI's Jalapeño announcement with Broadcom and signalling that every major AI lab now wants silicon independence from Nvidia.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        <tr>          <td style=\"padding:0 0 12px 0\">            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"                   style=\"background:#ffffff;border-radius:8px;border:1px solid #C2CCD5;border-left:3px solid #CF512B\">              <tr>                <td style=\"padding:20px 22px\" bgcolor=\"#ffffff\">                  <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">                    <tr>                      <td width=\"48\" valign=\"top\" style=\"padding:0 14px 0 0\">                        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">                          <tr><td width=\"36\" height=\"36\" align=\"center\" bgcolor=\"#CF512B\"                                  style=\"width:36px;height:36px;border-radius:50%;background:#CF512B;text-align:center;line-height:36px\">                            <font color=\"#ffffff\" face=\"Geist,Arial,sans-serif\"><b style=\"font-size:15px\">5</b></font>                          </td></tr>                        </table>                      </td>                      <td valign=\"middle\">                        <p style=\"margin:0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif;line-height:1.3\">                          <font color=\"#0A111A\"><b>Companies Are Throttling Employee AI Use as Token Costs Spiral</b></font>                        </p>                        <p style=\"margin:4px 0 0 0;font-size:11px;font-family:Geist,Arial,sans-serif;text-transform:uppercase;letter-spacing:0.1em\">                          <font color=\"#CF512B\">404 Media</font>                        </p>                      </td>                    </tr>                    <tr>                      <td colspan=\"2\" style=\"padding-top:10px\">                        <p style=\"margin:0;font-size:14px;font-family:Geist,Arial,sans-serif;line-height:1.6\">                          <font color=\"#41488A\">Internal documents and sources from Amazon, Adobe, Atlassian, Citi, and other large enterprises reveal that companies are actively capping or throttling employee AI usage because costs have exceeded budgets.</font>                        </p>                      </td>                    </tr>                  </table>                </td>              </tr>            </table>          </td>        </tr>        </table>      </td>    </tr>    <!-- READ ONLINE BUTTON -->    <tr>      <td style=\"background:#FAF7E6;padding:0 32px 24px;border-left:1px solid #C2CCD5;border-right:1px solid #C2CCD5\" bgcolor=\"#FAF7E6\">        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">          <tr>            <td align=\"center\">              <a href=\"https://ironbridge-ai.github.io/Austen/austen_2026-07-06.html\" target=\"_blank\"                 style=\"display:inline-block;background:#CF512B;color:#ffffff;font-family:'Charger',Georgia,'Times New Roman',serif;font-size:13px;font-weight:700;text-decoration:none;padding:12px 28px;border-radius:8px\">                <font color=\"#ffffff\"><b>Read full edition online &rarr;</b></font>              </a>            </td>          </tr>        </table>      </td>    </tr>    <!-- FOOTER -->    <tr>      <td style=\"background:#0A111A;border-radius:0 0 12px 12px;padding:28px 36px;border:1px solid #0A111A\" bgcolor=\"#0A111A\">        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">          <tr>            <td>              <p style=\"margin:0 0 4px 0;font-size:15px;font-weight:700;font-family:'Charger',Georgia,'Times New Roman',serif\">                <font color=\"#ffffff\"><b>Stay curious, stay ahead.</b></font>              </p>              <p style=\"margin:0;font-size:13px;font-family:Geist,Arial,sans-serif\">                <font color=\"#8E949D\">See you next week.</font>              </p>            </td>            <td align=\"right\">              <p style=\"margin:0;font-size:11px;font-weight:800;font-family:'Charger',Georgia,'Times New Roman',serif;letter-spacing:-0.01em\">                <font color=\"#ffffff\"><b>Thought Provoked</b></font>              </p>              <p style=\"margin:2px 0 0 0;font-size:10px;font-family:Geist,Arial,sans-serif\">                <font color=\"#545C65\">Weekly AI Briefing</font>              </p>            </td>          </tr>        </table>      </td>    </tr>  </table></td></tr></table></body></html>"}
    open newMessage
end tell

APPLESCRIPT
